davidneto.eu, www.davidneto.eu {
	reverse_proxy app:8080 {
		header_up X-Forwarded-For {http.request.remote.host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
	}
}

cloud.davidneto.eu {
	rewrite * /webdav{uri}
	reverse_proxy app:8080 {
		header_up X-Forwarded-For {http.request.remote.host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
	}
}
